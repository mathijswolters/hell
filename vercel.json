{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "^/jackpot/(.+)$",
      "destination": "http://116.202.242.165:2052/jackpot/$1"
    },
    {
      "source": "^/user/(.+)$",
      "destination": "http://116.202.242.165:2052/user/$1"
    },
    {
      "source": "^/stats/(.+)$",
      "destination": "http://116.202.242.165:2052/stats/$1"
    },
    {
      "source": "^/inventory/(.+)$",
      "destination": "http://116.202.242.165:2052/inventory/$1"
    },
    {
      "source": "^/steam-api/(.*)$",
      "destination": "https://api.steampowered.com/$1"
    },
    {
      "source": "^/socket\\.io($|/.*)$",
      "destination": "http://116.202.242.165:2082/socket.io$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
